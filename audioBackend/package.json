{
  "name": "audiobackend",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "inngest": "npx inngest-cli@latest dev",
    "db:init": "bun run scripts/db/init.ts",
    "db:clean": "bun run scripts/db/clean.ts",
    "db:deep-clean": "bun run scripts/db/deep-clean.ts",
    "recommendation:init": "bun run scripts/recommendation/init.ts",
    "recommendation:clean": "bun run scripts/recommendation/clean.ts",
    "recommendation:deep-clean": "bun run scripts/recommendation/deep-clean.ts",
    "search:init": "bun run scripts/search/init.ts",
    "search:clean": "bun run scripts/search/clean.ts",
    "search:deep-clean": "bun run scripts/search/deep-clean.ts",
    "init:all": "bun db:init && bun recommendation:init && bun search:init",
    "clean:all": "bun db:clean && bun recommendation:clean && bun search:clean",
    "deep-clean:all": "bun db:deep-clean && bun recommendation:deep-clean && bun search:deep-clean"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1027.0",
    "@imagekit/nodejs": "^7.4.0",
    "@neondatabase/serverless": "^1.0.2",
    "algoliasearch": "^5.50.1",
    "assemblyai": "^4.29.0",
    "axios": "^1.14.0",
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "imagekit": "^6.0.0",
    "inngest": "^4.2.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "recombee-api-client": "^6.1.0",
    "zod": "^4.3.6"
  }
}
